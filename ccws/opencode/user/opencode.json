{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "snapshot": false,
  "watcher": {
    "ignore": [".git/**"]
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "{env:OPENAI_BASE_URL}",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "{env:OPENAI_MODEL}": {
          "name": "{env:OPENAI_MODEL}"
        }
      }
    }
  },
  "enabled_providers": ["ollama"],
  "skills": {
    "paths": [
      "/ccws/skills"
    ]
  }
}
